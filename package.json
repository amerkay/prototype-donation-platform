{
  "name": "prototype-donation-platform",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "analyze": "nuxt analyze",
    "typecheck": "nuxt typecheck && echo FINISHED",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && echo FINISHED",
    "format": "prettier --check --log-level warn ./app/ ./test/",
    "format:fix": "prettier --write --log-level warn ./app/ ./test/ && echo FINISHED",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:nuxt": "vitest run --project nuxt",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "analyze:dead": "knip",
    "analyze:dupes": "jscpd",
    "analyze:long": "tsx scripts/long-files.ts",
    "analyze:circular": "madge --circular --ts-config tsconfig.json --extensions ts --exclude '^components/ui/' app/"
  },
  "jscpd": {
    "path": [
      "app"
    ],
    "threshold": 5,
    "minLines": 8,
    "minTokens": 50,
    "ignore": [
      "**/.nuxt/**",
      "**/node_modules/**",
      "**/sample-api-responses/**"
    ],
    "reporters": [
      "console"
    ]
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@internationalized/date": "^3.11.0",
    "@netlify/blobs": "^10.7.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/hints": "1.0.0-alpha.9",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@pinia/nuxt": "0.11.3",
    "@sparticuz/chromium": "^143.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/vue-table": "^8.21.3",
    "@tiptap/extension-character-count": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/vue-3": "^3.20.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "emojibase-data": "^17.0.0",
    "exceljs": "^4.4.0",
    "isomorphic-dompurify": "3.0.0",
    "lucide-vue-next": "^0.575.0",
    "nodemailer": "^8.0.1",
    "nuxt": "^4.3.1",
    "nuxt-email-renderer": "^2.5.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "puppeteer-core": "^24.37.5",
    "reka-ui": "^2.8.2",
    "shadcn-nuxt": "2.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9",
    "zod": "3.24.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.94",
    "@nuxt/test-utils": "^4.0.0",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "jscpd": "^4.0.8",
    "knip": "^5.85.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}